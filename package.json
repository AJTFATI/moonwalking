{
  "name": "astro-photo-folio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && node scripts/strip-unreferenced-assets.mjs",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "setup": "npm run gen:brand && npm run gen:icons && npm run gen:placeholders",
    "gen:brand": "node scripts/generate-brand.mjs",
    "gen:icons": "node scripts/generate-icons.mjs",
    "gen:placeholders": "node scripts/generate-placeholders.mjs",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/cormorant-garamond": "^5.0.0",
    "@fontsource/eb-garamond": "^5.0.0",
    "astro": "^7.0.6"
  },
  "devDependencies": {
    "wrangler": "^4.110.0"
  }
}
